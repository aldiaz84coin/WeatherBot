{
  "name": "madrid-temp-bot",
  "private": true,
  "packageManager": "pnpm@8.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "workspaces": [
    "packages/bot",
    "packages/dashboard"
  ],
  "scripts": {
    "bot": "pnpm --filter bot dev",
    "dashboard": "pnpm --filter dashboard dev",
    "backtest": "pnpm --filter bot backtest",
    "build": "pnpm --filter bot build && pnpm --filter dashboard build"
  }
}
